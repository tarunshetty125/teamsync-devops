# ─────────────────────────────────────────────────────────────
# Environment Variables for Docker Compose
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# MongoDB Atlas Connection (replace with your Atlas URI)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/teamsync_db?retryWrites=true&w=majority

# Session Configuration
SESSION_SECRET=your-session-secret-key
SESSION_EXPIRES_IN=1d

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost/api/v1/auth/google/callback

# Frontend URLs
FRONTEND_ORIGIN=http://localhost
FRONTEND_GOOGLE_CALLBACK_URL=http://localhost/login/callback

# Email Configuration (for notifications)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Grafana Credentials (change in production)
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin123
