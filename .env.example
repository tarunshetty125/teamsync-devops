# ─────────────────────────────────────────────────────────────
# Environment Variables for Docker Compose
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# MongoDB Atlas Connection (replace with your Atlas URI)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/teamsync_db?retryWrites=true&w=majority

# Session Configuration
SESSION_SECRET=replace-with-at-least-32-random-characters
SESSION_EXPIRES_IN=1d

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://teamsyncin.duckdns.org/api/v1/auth/google/callback

# Frontend URLs
FRONTEND_ORIGIN=https://teamsyncin.duckdns.org
FRONTEND_GOOGLE_CALLBACK_URL=https://teamsyncin.duckdns.org/login/callback
VITE_API_BASE_URL=https://teamsyncin.duckdns.org/api/v1

# Local File Storage
LOCAL_FILE_STORAGE_DIR=/app/uploads
MAX_ATTACHMENT_BYTES=10485760
MAX_AVATAR_BYTES=2097152

# TLS Certificate Mounts for Nginx
TLS_CERT_PATH=/etc/letsencrypt/live/teamsyncin.duckdns.org/fullchain.pem
TLS_KEY_PATH=/etc/letsencrypt/live/teamsyncin.duckdns.org/privkey.pem

# Grafana Credentials (change in production)
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=replace-with-random-grafana-password
