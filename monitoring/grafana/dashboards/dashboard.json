{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (method, path, status_class) (rate(teamsync_http_requests_total[5m]))",
          "legendFormat": "{{method}} {{path}} {{status_class}}"
        }
      ]
    },
    {
      "title": "Average Response Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (method, path) (rate(teamsync_http_request_duration_ms_total[5m])) / sum by (method, path) (rate(teamsync_http_requests_total[5m]))",
          "legendFormat": "{{method}} {{path}}"
        }
      ]
    },
    {
      "title": "Active Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "nginx_connections_active",
          "legendFormat": "connections"
        }
      ]
    },
    {
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "sum(teamsync_http_requests_total)",
          "legendFormat": "total"
        }
      ]
    },
    {
      "title": "Memory Usage (MB)",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "teamsync_process_memory_bytes{type=\"rss\"} / 1024 / 1024",
          "legendFormat": "RSS"
        }
      ]
    },
    {
      "title": "Process Uptime",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "teamsync_process_uptime_seconds",
          "legendFormat": "uptime"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["teamsync", "devops"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "TeamSync DevOps Dashboard",
  "uid": "teamsync-main",
  "version": 2
}
